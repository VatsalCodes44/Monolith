// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Player {
  publicKey       String         @id
  devnetLamports  BigInt         @default(0)
  mainnetLamports BigInt         @default(0)
  skr             BigInt         @default(0)
  gameAsPlayer1   Game[]         @relation("Player1")
  gameAsPlayer2   Game[]         @relation("Player2")
  nfts            PlayerNft[]
  transactions    Transactions[]
}

// player 1 is always white
model Game {
  id               String     @id @default(uuid())
  player1PublicKey String
  player2PublicKey String
  fen              String
  winner           Color?
  status           GameStatus
  network          Network
  timer1           BigInt     @default(600000)
  timer2           BigInt     @default(600000)
  history          String?
  lamports         BigInt     @default(0)
  customGame       Boolean    @default(false)
  skr              BigInt     @default(0)
  createdAt        DateTime   @default(now())
  player1          Player     @relation("Player1", fields: [player1PublicKey], references: [publicKey])
  player2          Player     @relation("Player2", fields: [player2PublicKey], references: [publicKey])
}

enum Network {
  MAINNET
  DEVNET
}

enum GameStatus {
  IN_PROGRESS
  DRAW
  CHECKMATE
  STALEMATE
  TIME_OUT
}

enum Color {
  w
  b
}

model PlayerNft {
  id        String   @id @default(uuid())
  publicKey String
  mintedNft String
  network   Network
  createdAt DateTime @default(now())
  player    Player   @relation(fields: [publicKey], references: [publicKey])
}

enum Asset {
  SOL
  SKR
}

model Transactions {
  signature String   @id
  from      String
  to        String
  asset     Asset
  amount    BigInt
  network   Network
  createdAt DateTime @default(now())
  player    Player   @relation(fields: [from], references: [publicKey])
}
