// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Player {
  publicKey           String         @id
  devnetLamports      BigInt         @default(0)
  mainnetLamports     BigInt         @default(0)
  skr                 BigInt         @default(0)
  
  devnetRating        Int            @default(100)
  mainnetRating       Int            @default(100)

  peakDevnetRating    Int            @default(100)
  peakMainnetRating   Int            @default(100)

  devnetWins          Int            @default(0)
  devnetLoss          Int            @default(0)     
  devnetDraw          Int            @default(0) 
  mainnetWins         Int            @default(0)
  mainnetLoss         Int            @default(0)     
  mainnetDraw         Int            @default(0)
  devnetSolWon        BigInt         @default(0)
  mainnetSolWon       BigInt         @default(0)

  devnetSolLost        BigInt         @default(0)
  mainnetSolLost      BigInt         @default(0)

  skrUsed             BigInt         @default(0)
  gameAsPlayer1       Game[]         @relation("Player1")
  gameAsPlayer2       Game[]         @relation("Player2")
  transactions        Transactions[]
}

// player 1 is always white
model Game {
  id               String     @id @default(uuid())
  player1PublicKey String
  player2PublicKey String
  fen              String
  winner           Color?
  status           GameStatus
  network          Network
  timer1           BigInt     @default(600000)
  timer2           BigInt     @default(600000)
  history          String?
  lamports         BigInt     @default(0)
  customGame       Boolean    @default(false)
  skr              BigInt     @default(0)
  createdAt        DateTime   @default(now())
  player1          Player     @relation("Player1", fields: [player1PublicKey], references: [publicKey])
  player2          Player     @relation("Player2", fields: [player2PublicKey], references: [publicKey])
}

enum Network {
  MAINNET
  DEVNET
}

enum GameStatus {
  IN_PROGRESS
  DRAW
  CHECKMATE
  STALEMATE
  TIME_OUT
}

enum Color {
  w
  b
}

enum Asset {
  SOL
  SKR
}

model Transactions {
  signature String   @id
  from      String
  to        String
  asset     Asset
  amount    BigInt
  network   Network
  createdAt DateTime @default(now())
  player    Player   @relation(fields: [from], references: [publicKey])
}
